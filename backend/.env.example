# Feliy Backend — 环境变量配置
# 复制此文件为 .env 并填入你的真实密钥

# 中继密钥 — 前端 PWA 登录时输入此密钥
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
RELAY_SECRET=your-secret-here-change-me

# AI API 配置
# 可选: deepseek (Anthropic兼容) 或 anthropic (官方)
AI_ENDPOINT=deepseek
AI_API_KEY=sk-your-api-key-here
AI_MODEL=deepseek-chat

# 如果使用 Anthropic 官方
# AI_ENDPOINT=anthropic
# AI_API_KEY=sk-ant-...
# AI_MODEL=claude-sonnet-4-20250514

# 应用名称
RELAY_AI_NAME=Feliy
RELAY_HUMAN_NAME=Kunuon
